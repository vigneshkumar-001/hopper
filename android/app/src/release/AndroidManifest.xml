<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Release build: temporarily disable background location + location foreground service
      to avoid Play Console "Foreground service permissions" video requirement.
      (Foreground location permissions remain for in-app map usage.)
    -->

    <uses-permission
        android:name="android.permission.ACCESS_BACKGROUND_LOCATION"
        tools:node="remove" />

    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE"
        tools:node="remove" />

    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_LOCATION"
        tools:node="remove" />

    <application>
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            tools:node="remove" />
    </application>

</manifest>
